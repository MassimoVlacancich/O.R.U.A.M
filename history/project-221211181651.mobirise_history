 title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-md-12 col-lg-{{textWidth}}\" mbr-if=\"showTitle\">\n                <h3 class=\"mbr-section-title mbr-fonts-style mb-4\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\"><b>Attività in area Piemontese</b><br>In area piemontese la nostra Associazione si occupa di:</h3>\n            </div>\n        </div>\n        <div class=\"row justify-content-center\">\n            <div class=\"col-md-12 col-lg-{{textWidth}}\">\n                <div class=\"row justify-content-center\">\n                    <div class=\"col-12 col-lg-6\">\n                        <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list\" data-multiline mbr-article>\n                            <li><b>promuovere e sostenere iniziative volte all’integrazione scolastica</b> degli alunni&nbsp;<span style=\"font-size: 1.2rem;\">immigrati e degli alunni svantaggiati; anche mediante iniziative volte&nbsp;</span><span style=\"font-size: 1.2rem;\">all’alfabetizzazione e alla crescita culturale delle madri;</span></li>\n                            <li>intervenire nelle scuole per <b>diffondere la conoscenza di culture e sistemi sociali diversi</b> con particolare riguardo alla cultura del popolo Dogon (Mali).</li>\n                        </ul>\n                    </div>\n                    <div class=\"col-12 col-lg-6\" mbr-if=\"colAmount > 1\">\n                        <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list\" data-multiline mbr-article>\n                            <li>promuovere e mantenere <b>gemellaggi scolatic</b>i anche con corrispondenze epistolari come strumento didattico per lo <b>scambio interculturale</b> nei loro vari livelli evolutivi per la formazione di personalità orientate a valori quali fratellanza, pace, giustizia; </li><li>nello specifico, nell’ambito del gemellaggio scolastico fra le scuole di <b>Yendouma e l’Istituto Comprensivo di Bricherasio</b>, abbiamo favorito lo scambio di lettere, disegni e realizziam regolarmente lezioni in classe su costumi, usanze e geografia dei paesi Dogon.</li>\n                        </ul>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
